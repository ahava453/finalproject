{
    "name": "Sentiment Analysis Platform",
    "image": "mcr.microsoft.com/devcontainers/universal:2",
    "features": {
        "ghcr.io/devcontainers/features/node:1": {
            "version": "lts"
        },
        "ghcr.io/devcontainers/features/python:1": {
            "version": "3.11"
        }
    },
    "forwardPorts": [
        5173,
        8000
    ],
    "portsAttributes": {
        "5173": {
            "label": "Frontend (React)",
            "onAutoForward": "openBrowser"
        },
        "8000": {
            "label": "FastAPI Backend",
            "onAutoForward": "notify"
        }
    },
    "postCreateCommand": "bash .devcontainer/setup.sh",
    "secrets": {
        "APIFY_API_TOKEN": {
            "description": "Apify API Token for scraping Facebook/Instagram comments. Get a free token at https://apify.com"
        },
        "FACEBOOK_APP_ID": {
            "description": "Meta App ID (optional - only needed for Meta OAuth login flow)"
        },
        "FACEBOOK_APP_SECRET": {
            "description": "Meta App Secret (optional - only needed for Meta OAuth login flow)"
        },
        "META_VERIFY_TOKEN": {
            "description": "Webhook verify token for Meta (optional)"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "esbenp.prettier-vscode",
                "dbaeumer.vscode-eslint"
            ]
        }
    }
}